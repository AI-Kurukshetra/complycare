# =============================================================================
# ComplyCare — Environment Variables
# =============================================================================
# Use this template for both local development and production deployment.
# NEVER commit real values to source control.
#
# Development
# 1. Copy this file to `.env.local`.
# 2. Fill in the values below with your development or shared project keys.
# 3. Start the app with `npm run dev` or `docker compose -f docker/compose.yaml up`.
#
# Production
# 1. Do not commit a real production env file.
# 2. Add these same keys in your hosting platform secret manager or deployment
#    environment settings (for example Vercel, Docker, or your container host).
# 3. Keep `SUPABASE_SERVICE_ROLE_KEY` server-side only.
# 4. Set the optional Anthropic values only if AI routes should be enabled.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — required
# -----------------------------------------------------------------------------

# Your Supabase project URL (safe to expose to the client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (safe to expose to the client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key — SERVER-SIDE ONLY, never expose to the client.
# Used by admin API routes that bypass Row-Level Security (RLS).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Anthropic / Claude API — optional (AI features disabled if not set)
# -----------------------------------------------------------------------------
# Without ANTHROPIC_API_KEY the app runs normally but all AI endpoints
# (/api/ai/*) return 503. ANTHROPIC_MODEL and ANTHROPIC_VERSION have
# built-in defaults and do not need to be set explicitly.

# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_VERSION=2023-06-01
